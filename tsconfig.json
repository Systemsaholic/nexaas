{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@nexaas/palace": ["./packages/palace/src/index.ts"],
      "@nexaas/palace/*": ["./packages/palace/src/*"],
      "@nexaas/runtime": ["./packages/runtime/src/index.ts"],
      "@nexaas/runtime/*": ["./packages/runtime/src/*"],
      "@nexaas/integration-sdk": ["./packages/integration-sdk/src/index.ts"],
      "@nexaas/integration-sdk/*": ["./packages/integration-sdk/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "integrations/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
