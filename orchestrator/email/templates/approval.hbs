<!-- Approval: pending client decisions with action buttons -->
<h2 style="margin:0 0 8px;font-size:20px;font-weight:600;color:#1a1a1a;line-height:1.3;">
  Approval Required
</h2>
<p style="margin:0 0 24px;font-size:14px;color:#71717a;">
  An action needs your review before it can proceed.
</p>

<div style="margin:0 0 24px;padding:16px;background-color:#fafafa;border:1px solid #e4e4e7;border-radius:6px;">
  <p style="margin:0 0 8px;font-size:16px;font-weight:600;color:#1a1a1a;">{{summary}}</p>
  {{#if body}}
  <div style="margin:0;font-size:14px;color:#3f3f46;line-height:1.6;white-space:pre-wrap;">{{body}}</div>
  {{/if}}
</div>

{{#if details}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;border:1px solid #e4e4e7;border-radius:6px;overflow:hidden;">
  {{#each details}}
  <tr>
    <td style="padding:10px 14px;font-size:13px;font-weight:600;color:#71717a;background-color:#fafafa;border-bottom:1px solid #e4e4e7;width:140px;vertical-align:top;">
      {{@key}}
    </td>
    <td style="padding:10px 14px;font-size:13px;color:#3f3f46;border-bottom:1px solid #e4e4e7;vertical-align:top;">
      {{this}}
    </td>
  </tr>
  {{/each}}
</table>
{{/if}}

{{#if dashboardUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 24px;">
  <tr>
    <td style="background-color:#1a1a1a;border-radius:6px;padding:0;">
      <a href="{{dashboardUrl}}" style="display:inline-block;padding:12px 24px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Review in Dashboard
      </a>
    </td>
  </tr>
</table>
{{/if}}

{{#if expiresIn}}
<p style="margin:0;font-size:12px;color:#a1a1aa;">
  This request expires in {{expiresIn}}. If no action is taken, it will be flagged for operator review.
</p>
{{/if}}

{{#if skillId}}
<p style="margin:8px 0 0;font-size:12px;color:#a1a1aa;">
  Skill: {{skillId}}
</p>
{{/if}}
