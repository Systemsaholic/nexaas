<!-- Alert: escalations, flagged items, urgent failures -->
<div style="margin:-32px -32px 24px;padding:16px 32px;background-color:#fef2f2;border-bottom:1px solid #fecaca;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td style="font-size:14px;font-weight:600;color:#dc2626;">
        &#9888; {{summary}}
      </td>
    </tr>
  </table>
</div>

{{#if body}}
<div style="margin:0 0 24px;font-size:15px;color:#3f3f46;line-height:1.6;white-space:pre-wrap;">{{body}}</div>
{{/if}}

{{#if details}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;border:1px solid #fecaca;border-radius:6px;overflow:hidden;">
  {{#each details}}
  <tr>
    <td style="padding:10px 14px;font-size:13px;font-weight:600;color:#71717a;background-color:#fef2f2;border-bottom:1px solid #fecaca;width:140px;vertical-align:top;">
      {{@key}}
    </td>
    <td style="padding:10px 14px;font-size:13px;color:#3f3f46;border-bottom:1px solid #fecaca;vertical-align:top;">
      {{this}}
    </td>
  </tr>
  {{/each}}
</table>
{{/if}}

{{#if actionUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 16px;">
  <tr>
    <td style="background-color:#dc2626;border-radius:6px;">
      <a href="{{actionUrl}}" style="display:inline-block;padding:12px 24px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        View in Dashboard
      </a>
    </td>
  </tr>
</table>
{{/if}}

{{#if skillId}}
<p style="margin:0;font-size:12px;color:#a1a1aa;">
  Skill: {{skillId}} &bull; Severity: {{severity}}
</p>
{{/if}}
