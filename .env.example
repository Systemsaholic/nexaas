# Nexaas Framework — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === Required ===
NEXAAS_WORKSPACE=your-workspace-id
NEXAAS_ROOT=/opt/nexaas
NEXAAS_WORKSPACE_ROOT=/home/ubuntu/your-workspace
DATABASE_URL=postgresql://ubuntu:password@localhost/nexaas_palace
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=sk-ant-...

# === Worker ===
NEXAAS_WORKER_CONCURRENCY=5
NEXAAS_WORKER_PORT=9090
NEXAAS_BACKUP_DIR=/var/backups/nexaas

# === Optional: RAG Embeddings ===
VOYAGE_API_KEY=pa-...

# === Optional: Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
RESEND_API_KEY=
OPS_ALERT_EMAIL=
OPS_ALERT_FROM=Nexaas Alerts <alerts@nexmatic.ca>
