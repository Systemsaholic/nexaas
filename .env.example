# Nexaas Framework — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === Required ===
NEXAAS_WORKSPACE=your-workspace-id
NEXAAS_ROOT=/opt/nexaas
NEXAAS_WORKSPACE_ROOT=/home/ubuntu/your-workspace
DATABASE_URL=postgresql://ubuntu:password@localhost/nexaas_palace
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=sk-ant-...

# === Worker ===
NEXAAS_WORKER_CONCURRENCY=5
NEXAAS_WORKER_PORT=9090
NEXAAS_BACKUP_DIR=/var/backups/nexaas

# === Optional: RAG Embeddings ===
VOYAGE_API_KEY=pa-...

# === Optional: Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
RESEND_API_KEY=
OPS_ALERT_EMAIL=
OPS_ALERT_FROM=Nexaas Alerts <alerts@nexmatic.ca>

# === Optional: Silent-failure alerting ===
# Fires a notification when a single skill fails N consecutive runs.
# CHANNEL_ROLE unset → feature disabled. See #69.
NEXAAS_SILENT_FAILURE_THRESHOLD=
NEXAAS_SILENT_FAILURE_CHANNEL_ROLE=

# === Optional: Waitpoint timeout ceiling ===
# Default is 1 day. Raise for state-machine hold patterns (e.g. Stripe
# payment-failed retries, week-scale approval loops). See #66.
NEXAAS_WAITPOINT_MAX_TIMEOUT_DAYS=

# === Optional: Cross-VPS bearer auth (operator-managed mode) ===
# Gates /api/waitpoints/inbound-match and /api/drawers/inbound when set.
# Leave unset in direct-adopter mode (Phoenix-style) — endpoints remain open.
# See docs/adoption-patterns/multi-vps-channel-relay.md.
NEXAAS_CROSS_VPS_BEARER_TOKEN=
