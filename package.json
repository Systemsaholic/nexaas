{
  "name": "nexaas",
  "version": "0.1.0",
  "private": true,
  "description": "Nexaas — framework for context-aware AI execution",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify-wal": "npm -w @nexaas/cli run verify-wal",
    "validate-skill": "npm -w @nexaas/cli run validate-skill"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Systemsaholic/nexaas.git"
  },
  "author": "Systemsaholic",
  "license": "SEE LICENSE IN LICENSE"
}
