{
  "name": "nexaas",
  "version": "0.4.0",
  "private": true,
  "description": "Nexaas — framework for context-aware AI execution",
  "type": "module",
  "workspaces": [
    "packages/*",
    "integrations/*",
    "mcp/servers/email-outbound",
    "mcp/servers/palace"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify-wal": "npm -w @nexaas/cli run verify-wal",
    "validate-skill": "npm -w @nexaas/cli run validate-skill",
    "release-stamp": "node scripts/release-stamp.mjs",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Systemsaholic/nexaas.git"
  },
  "author": "Systemsaholic",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.1.10"
  }
}
